<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>Today - To Do App</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <aside>
    <div>
      <h2>Menu</h2>
      <hr>
      <ul>
        <li><a href="/today">📍 Today</a></li>
        <li><a href="/upcoming">⏳ Upcoming</a></li>
        <li><a href="/calendar">🗓️ Calendar</a></li>
        <li><a href="/home">📝 Sticky Wall</a></li>
      </ul>
      <div class="lists">
        <h3>Lists</h3>
        <ul>
          <li>🔴 High <span class="task-count"><%= counter.high %></span></li>
          <li>🟠 Medium <span class="task-count"><%= counter.medium %></span></li>
          <li>🟢 Low <span class="task-count"><%= counter.low %></span></li>
        </ul>
      </div>
    </div>
    <div class="bottom-links">
      <a href="/logout">🚪 Sign out</a>
    </div>
  </aside>
  <div class="main">
    <h1>📅 Today <span style="font-weight:normal; color:#888;">วันนี้</span></h1>
    <% if (completed_count > 0) { %>
      <div class="delete-completed-wrapper">
        <form action="/delete_completed" method="post" onsubmit="return confirm('คุณต้องการลบงานที่เสร็จแล้วทั้งหมดใช่หรือไม่?');">
          <button type="submit" class="btn-delete-completed">ลบงานที่เสร็จแล้ว (<%= completed_count %>)</button>
        </form>
      </div>
    <% } %>
    <div class="today-list">
      <% if (today_notes.length === 0) { %>
        <p style="text-align:center; margin-top: 20px;">🎉 ยอดเยี่ยม! ไม่มีรายการสำหรับวันนี้</p>
      <% } else { %>
        <% today_notes.forEach(note => { %>
          <div class="today-note <%= note.is_completed ? 'completed' : '' %>" style="border-left-color: <%= note.color %>">
            <div class="note-status">
              <input type="checkbox" class="task-checkbox" data-note-id="<%= note.id %>" <%= note.is_completed ? 'checked' : '' %> />
            </div>
            <div class="note-info">
              <h3><%= note.title %></h3>
              <% if (note.content) { %>
                <p><%= note.content.replace(/\n/g, '<br>') %></p>
              <% } %>
            </div>
            <div class="note-priority">
              <span class="priority-tag priority-<%= note.priority %>"><%= note.priority %></span>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
  <script>
    document.querySelectorAll('.task-checkbox').forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const noteId = this.dataset.noteId;
        const isCompleted = this.checked;
        fetch('/toggle_status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ note_id: noteId, status: isCompleted })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            window.location.reload();
          } else {
            alert('เกิดข้อผิดพลาดในการอัปเดตสถานะ');
          }
        })
        .catch(() => alert('เกิดข้อผิดพลาดในการเชื่อมต่อ'));
      });
    });
  </script>
</body>
</html>
